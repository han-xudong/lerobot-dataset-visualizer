{
  "name": "lerobot-viewer",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop and web visualizer for LeRobot datasets.",
  "author": {
    "name": "Han Xudong",
    "email": "hanxudong159@126.com"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "bun run generate:icons && next build",
    "build:ci": "next build",
    "start": "next start",
    "generate:icons": "node scripts/generate-icons.mjs",
    "desktop:dev": "node scripts/ensure-electron-dist.mjs && node scripts/electron-dev.mjs",
    "desktop:build": "bun run build && node scripts/prepare-electron-dist.mjs",
    "desktop:build:ci": "bun run build:ci && node scripts/prepare-electron-dist.mjs",
    "desktop:dist": "node scripts/ensure-electron-dist.mjs && bun run desktop:build && electron-builder --publish never --config electron-builder.config.cjs",
    "desktop:dist:ci": "node scripts/ensure-electron-dist.mjs && bun run desktop:build:ci && electron-builder --publish never --config electron-builder.config.cjs",
    "desktop:dist:dir": "node scripts/ensure-electron-dist.mjs && bun run desktop:build && electron-builder --publish never --config electron-builder.config.cjs --dir",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "bun test",
    "validate": "bun run type-check && bun run lint && bun run format:check && bun test"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "hyparquet": "^1.12.1",
    "next": "15.3.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "recharts": "^2.15.3",
    "three": "^0.182.0",
    "urdf-loader": "^0.12.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.182.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "icon-gen": "^5.0.0",
    "prettier": "^3.5.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
